# ─── Local Development ────────────────────────────────────────
PORT=4000
DATABASE_URL=postgres://career_align:career_align@localhost:5432/career_align
FRONTEND_URL=http://localhost:3000

EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

JOB_SOURCES=LinkedIn,Internshala,Indeed,Glassdoor,WeWorkRemotely
JOB_TERM_LIMIT=6
SCRAPE_CRON=0 */6 * * *
SCRAPE_TIMEZONE=Asia/Kolkata

MAIL_DRIVER=console
MAIL_FROM=no-reply@career-align.local
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ─── Render Deployment (render.yaml overrides these) ─────────
# DATABASE_URL is auto-provided by Render managed PostgreSQL.
# FRONTEND_URL is auto-set from the frontend service URL.
# NEXT_PUBLIC_API_URL is auto-set from the backend service URL.
