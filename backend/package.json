{
  "name": "career-align",
  "version": "1.0.0",
  "description": "Student job matching portal with resume parsing and job aggregator.",
  "main": "server.js",
  "scripts": {
    "start": "node gateway/index.js",
    "dev": "node --watch gateway/index.js",
    "scrape": "node utils/scraperService.js",
    "reembed": "node utils/reembedJobs.js",
    "test:recommendations": "node tests/recommendationSmoke.js",
    "worker:refresh": "node workers/jobRefreshWorker.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.0",
    "bcrypt": "^5.1.0",
    "@crawlee/cheerio": "^3.16.0",
    "@crawlee/playwright": "^3.16.0",
    "@crawlee/puppeteer": "^3.16.0",
    "@xenova/transformers": "^2.17.2",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mammoth": "^1.4.21",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "openai": "^6.39.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "playwright": "^1.38.0",
    "puppeteer": "^25.0.4"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=18"
  }
}
